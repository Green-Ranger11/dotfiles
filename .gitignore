# Dotfiles .gitignore - Blocklist approach
# Files are added explicitly one by one (`config add <file>`).
# No whitelist needed; this only guards against secrets/junk slipping in.

# ============================================
# SECURITY & PRIVACY
# ============================================

# SSH keys and config
.ssh/

# GPG keys
.gnupg/

# Credentials and secrets
**/*credentials*
**/*secret*
**/*.pem
**/*.key
**/*.env
**/.env*

# Tokens and auth
**/*token*
**/.auth*
**/auth.json

# Browser data
.mozilla/
.config/chromium/
.config/google-chrome/
.config/BraveSoftware/

# History files
.*_history
.bash_history
.zsh_history
.python_history
.node_repl_history

# ============================================
# JUNK
# ============================================

# Cache directories
.cache/
**/.cache/
**/cache/
**/*cache*/

# Package managers
node_modules/
.npm/
.yarn/
.cargo/
.rustup/
.gem/

# Compiled binaries in sketchybar
.config/sketchybar/helpers/menus/bin/

# IDE/Editor state
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.bak
*.backup
*.orig

# VPN configs (plaintext passwords)
.config/openfortivpn/

# Work-specific shell config (internal hosts)
.config/zsh/work.zsh
